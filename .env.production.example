# ─────────────────────────────────────────────
# Vitaro — Production environment (Hostinger VPS)
# Copy this file to ".env" on the server and fill real values.
# Never commit the real ".env" file.
# ─────────────────────────────────────────────

# PostgreSQL connection string (local DB on the same VPS).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://vitaro_user:STRONG_DB_PASSWORD@localhost:5432/vitaro"

# NextAuth — generate a strong secret with:  openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_OUTPUT_OF_openssl_rand_base64_32"
# Must match your real public domain (with https).
NEXTAUTH_URL="https://your-domain.com"

# Admin panel password (login at /admin/login). Use a strong value.
ADMIN_PASSWORD="REPLACE_WITH_STRONG_ADMIN_PASSWORD"

# Public site URL used for SEO, sitemap, canonical, OG.
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Locale / currency
NEXT_PUBLIC_DEFAULT_LOCALE="ar"
NEXT_PUBLIC_DEFAULT_CURRENCY="MAD"

# Optional analytics / pixels (leave empty if unused)
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
